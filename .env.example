# ─── Football Data (https://www.football-data.org) ───────────────────────────
# Free tier works for Premier League; La Liga needs a separate paid key.
VITE_FD_API_KEY=your_football_data_api_key_here
FD_API_KEY_LALIGA=your_football_data_laliga_key_here

# ─── Firebase Admin SDK (server-side only — from a service account JSON) ─────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Resend (transactional email for password reset + picks reminder) ────────
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL="Points Are Bad <noreply@pab.wtf>"

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of the deployed app. Used to build password-reset links and the
# CTA in picks-reminder emails. Defaults to https://pab.wtf if unset.
APP_URL=https://pab.wtf

# Set to "production" on Vercel so session cookies are flagged Secure.
# Leave unset locally so cookies work over plain http://localhost.
NODE_ENV=production
